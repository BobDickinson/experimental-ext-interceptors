#!/usr/bin/env bash
set -euo pipefail

# Skip Go checks if no Go files are staged
if ! git diff --cached --name-only | grep -q '\.go$'; then
  echo "==> No Go files staged, skipping Go checks"
  exit 0
fi

cd go/sdk

echo "==> gofmt"
gofmt -w .

echo "==> go vet"
go vet ./...

echo "==> staticcheck"
staticcheck ./...
